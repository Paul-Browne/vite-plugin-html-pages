{
  "name": "vite-plugin-htjs-pages",
  "version": "1.0.1",
  "author": "Paul Browne",
  "type": "module",
  "keywords": [
    "vite",
    "vite-plugin",
    "vite-plugin-pages",
    "vite-ssg",
    "static-site-generator",
    "ssg",
    "file-based-routing",
    "html-generator",
    "javascript-to-html",
    "static-html",
    "blog-generator"
  ],  
  "description": "Minimal static site generation (SSG) for Vite using JavaScript functions that return HTML",
  "homepage": "https://github.com/paulbrowne/vite-plugin-htjs-pages",
  "repository": {
    "type": "git",
    "url": "https://github.com/paulbrowne/vite-plugin-htjs-pages.git"
  },
  "bugs": {
    "url": "https://github.com/paulbrowne/vite-plugin-htjs-pages/issues"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test:dev": "vite",
    "test:build": "vite build",
    "test:preview": "vite preview"
  },
  "peerDependencies": {
    "vite": ">=5"
  },
  "dependencies": {
    "@rollup/plugin-node-resolve": "^16.0.3",
    "fast-glob": "^3.3.3",
    "p-limit": "^4.0.0",
    "rollup": "^4.34.6"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^20.17.0",
    "javascript-to-html": "^1.1.1",
    "tsup": "^8.3.6",
    "typescript": "^5.7.3",
    "vite": "^6.4.1"
  }
}
