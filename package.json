{
  "name": "vite-plugin-html-pages",
  "version": "1.6.0",
  "author": "Paul Browne",
  "type": "module",
  "license": "MIT",
  "keywords": [
    "vite",
    "vite-plugin",
    "vite-plugin-pages",
    "vite-ssg",
    "static-site-generator",
    "ssg",
    "file-based-routing",
    "html-generator",
    "javascript-to-html",
    "static-html",
    "blog-generator"
  ],
  "files": [
    "dist/**/*"
  ],
  "description": "Minimal static site generation (SSG) for Vite using JavaScript functions that return HTML",
  "homepage": "https://github.com/paul-browne/vite-plugin-html-pages",
  "repository": {
    "type": "git",
    "url": "https://github.com/paul-browne/vite-plugin-html-pages.git"
  },
  "bugs": {
    "url": "https://github.com/paul-browne/vite-plugin-html-pages/issues"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./page": {
      "types": "./dist/page.d.ts",
      "import": "./dist/page.js"
    },
    "./jsx-runtime": {
      "types": "./dist/jsx-runtime.d.ts",
      "import": "./dist/jsx-runtime.js"
    },
    "./jsx-dev-runtime": {
      "types": "./dist/jsx-dev-runtime.d.ts",
      "import": "./dist/jsx-dev-runtime.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test:dev": "vite",
    "test:build": "vite build",
    "test:preview": "vite preview"
  },
  "peerDependencies": {
    "vite": ">=5"
  },
  "dependencies": {
    "esbuild": "^0.24.0",
    "fast-glob": "^3.3.3",
    "javascript-to-html": "^1.1.3",
    "p-limit": "^4.0.0"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^20.17.0",
    "tsup": "^8.3.6",
    "typescript": "^5.7.3",
    "vite": "^6.4.1"
  }
}
